generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ORG_ADMIN
  FIELD_MANAGER
  MARKET_MANAGER
}

enum CameraStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum ScopeType {
  FIELD
  MARKET
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  IMPORT
  EXPORT
}

// ─── Auth.js required models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ───────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  name      String
  email     String?   @unique
  password  String?
  role      Role      @default(MARKET_MANAGER)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accounts Account[]
  sessions Session[]
  scopes   UserScope[]
}

model UserScope {
  id        String    @id @default(cuid())
  userId    String
  scopeType ScopeType
  fieldId   String?
  marketId  String?
  createdAt DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  field  Field?  @relation(fields: [fieldId], references: [id])
  market Market? @relation(fields: [marketId], references: [id])

  @@unique([userId, scopeType, fieldId, marketId])
}

model Field {
  id        String    @id @default(cuid())
  name      String
  address   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  markets Market[]
  cameras Camera[]
  scopes  UserScope[]
}

model Market {
  id        String    @id @default(cuid())
  name      String
  address   String?
  fieldId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  field   Field       @relation(fields: [fieldId], references: [id])
  booths  Booth[]
  cameras Camera[]
  scopes  UserScope[]
  regions Region[]
}

model BoothCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  booths Booth[]
}

model Booth {
  id         String    @id @default(cuid())
  number     String
  marketId   String
  categoryId String
  ownerId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  market   Market        @relation(fields: [marketId], references: [id])
  category BoothCategory @relation(fields: [categoryId], references: [id])
  cameras  Camera[]
  regions  RegionBooth[]

  @@unique([marketId, number])
}

model Camera {
  id        String       @id @default(cuid())
  name      String
  streamUrl String?
  status    CameraStatus @default(UNKNOWN)
  fieldId   String?
  marketId  String?
  boothId   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  field  Field?  @relation(fields: [fieldId], references: [id])
  market Market? @relation(fields: [marketId], references: [id])
  booth  Booth?  @relation(fields: [boothId], references: [id])

  regions CameraRegion[]
}

// ─── Region Management ──────────────────────────────────────────────────────
//
// A Region is a user-defined spatial area inside a Market. It is intentionally
// geometry-free: the same logical Region can be seen by many cameras, and each
// camera stores its OWN polygon for the portion it sees (see CameraRegion).
//
//   Region ──< CameraRegion >── Camera     (M:N, geometry lives on the edge)
//   Region ──< RegionBooth   >── Booth      (M:N, "Stall mapping")
//
// "Stall" in the product spec maps to the existing Booth entity.

model Region {
  id          String    @id @default(cuid())
  name        String
  description String?
  marketId    String
  color       String? // optional UI hint, e.g. "#22c55e"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  market        Market         @relation(fields: [marketId], references: [id])
  cameraRegions CameraRegion[]
  booths        RegionBooth[]

  // Unique region name per market (case-insensitive enforced in the service layer).
  @@unique([marketId, name])
  @@index([marketId])
}

// The Camera <-> Region edge. Owns the geometry for how a single camera sees a
// single region. EffectiveArea = mainPolygon - exclusionPolygons.
//
// Coordinates are normalized floats in [0,1] relative to the camera frame
// (resolution-independent). Shapes:
//   mainPolygon        : Json  -> Point[]      e.g. [{ "x": 0.1, "y": 0.2 }, ...]
//   exclusionPolygons  : Json  -> Point[][]    e.g. [[ {x,y}, ... ], ...]
model CameraRegion {
  id                String    @id @default(cuid())
  cameraId          String
  regionId          String
  mainPolygon       Json
  exclusionPolygons Json      @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  camera Camera @relation(fields: [cameraId], references: [id])
  region Region @relation(fields: [regionId], references: [id])

  // One mapping per (camera, region) pair.
  @@unique([cameraId, regionId])
  @@index([regionId])
  @@index([cameraId])
}

// The Region <-> Booth (Stall) edge. Pure association; business users decide it.
model RegionBooth {
  id        String    @id @default(cuid())
  regionId  String
  boothId   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  region Region @relation(fields: [regionId], references: [id])
  booth  Booth  @relation(fields: [boothId], references: [id])

  @@unique([regionId, boothId])
  @@index([regionId])
  @@index([boothId])
}

// Generic, append-only audit trail for sensitive mutations.
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String? // User.id (nullable: keep history if user removed)
  actorName  String?
  action     AuditAction
  entityType String // "Region" | "CameraRegion" | "RegionBooth"
  entityId   String
  marketId   String? // denormalized for scope-filtered audit queries
  metadata   Json? // before/after snapshot or diff
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([marketId])
  @@index([createdAt])
}
