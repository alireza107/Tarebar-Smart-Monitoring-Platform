# Normalize line endings to LF in the repository; check out as-is on all platforms
* text=auto eol=lf

# Explicitly LF for all text source files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.sh        text eol=lf
*.sql       text eol=lf
*.prisma    text eol=lf
*.toml      text eol=lf
*.lock      text eol=lf
*.txt       text eol=lf
Dockerfile  text eol=lf
Dockerfile* text eol=lf
.gitignore  text eol=lf
.npmrc      text eol=lf

# Binary — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
